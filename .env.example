# readmission-risk-scorer environment variables
# Copy to .env and edit as needed

# Demo track: set true to return mock fixtures (no model loading, no API key needed)
MOCK_MODEL=true

# Set true to bypass the optional LLM narrative call in /predict/explain
MOCK_LLM=true

# Required only for /predict/explain with MOCK_LLM=false
ANTHROPIC_API_KEY=

# Risk tier thresholds (configurable; affects precision/recall tradeoff)
HIGH_THRESHOLD=0.65
MODERATE_THRESHOLD=0.35

# Inference API port
INFERENCE_API_PORT=8000

# Set "azure_ml" for cloud cost computation; "local" for near-zero local cost
INFERENCE_MODE=local

# Azure ML endpoint (hyperscaler track only)
AZURE_ML_ENDPOINT_NAME=readmission-risk-scorer-v1
AZURE_ML_ENDPOINT_URL=
AZURE_ML_API_KEY=
